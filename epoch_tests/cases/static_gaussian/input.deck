begin:control
  nx = 160
  ny = 192
  t_end = 18 * femto
  x_min = 0
  x_max = 8 * micron
  y_min = -6 * micron
  y_max = 6 * micron
  stdout_frequency = 50
end:control

begin:boundaries
  bc_x_min = simple_laser
  bc_x_max = open
  bc_y_min = open
  bc_y_max = open
end:boundaries

begin:laser
  boundary = x_min
  intensity_w_cm2 = 1e16
  lambda = 1 * micron
  pol = 0
  t_start = 0
  t_end = 14 * femto
  t_profile = gauss(time, 7 * femto, 2 * femto)

  use_custom_profile = T
  use_spatiotemporal_profile = F
  profile_data_file = amplitude.dat
  n_y = 257
  y_min = -6 * micron
  y_max = 6 * micron
  use_phase_from_file = T
  phase_data_file = phase.dat
end:laser

begin:output
  dt_snapshot = 2 * femto
  grid = always
  ey = always
  bz = always
end:output
